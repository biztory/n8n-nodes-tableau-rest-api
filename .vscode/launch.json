{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug: n8n-node dev",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "npm",
			"runtimeArgs": ["run", "dev"],
			"env": {
				"NODE_OPTIONS": "--inspect"
			},
			"autoAttachChildProcesses": true,
			"skipFiles": ["<node_internals>/**"],
			"console": "integratedTerminal"
		},
		{
			"name": "Attach to running n8n",
			"processId": "${command:PickProcess}",
			"request": "attach",
			"skipFiles": ["<node_internals>/**"],
			"type": "node"
		}
	]
}
