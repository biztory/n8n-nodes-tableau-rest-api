{
    "name": "@biztory/n8n-nodes-tableau-rest-api",
    "version": "0.2.0",
    "description": "n8n community node for the Tableau REST API",
    "license": "MIT",
    "homepage": "https://www.biztory.com",
    "keywords": [
        "n8n-community-node-package",
        "tableau",
        "rest api",
        "data",
        "analytics",
        "business intelligence"
    ],
    "author": {
        "name": "Timothy Vermeiren",
        "email": "timothy.vermeiren@biztory.be"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/biztory/n8n-nodes-tableau-rest-api.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/TableauRestApiApi.credentials.js",
            "dist/credentials/TableauRestApiPatApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/TableauRestApi/TableauRestApi.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "^0.23.1",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    }
}
